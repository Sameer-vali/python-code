n = int(input("Enter number of teams: "))
teams = []
for i in range(n):
    x = input("Enter team name: ")
    teams.append(x)

matches = []

for i in range(n - 1):
    for j in range(i + 1, n):
        matches.append([teams[i], teams[j]])
pos = 1
for match in matches:
    print("Match {} : {} vs {}".format(pos, match[0], match[1]))
    pos = pos + 1
